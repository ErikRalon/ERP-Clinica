generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Paciente {
  id               Int       @id @default(autoincrement())
  nombres          String
  apellidos        String
  dpi              String    @unique
  fechaNacimiento  DateTime
  telefono         String?
  email            String?
  direccion        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}